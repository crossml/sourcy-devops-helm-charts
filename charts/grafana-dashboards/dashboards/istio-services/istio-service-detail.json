{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Incoming Request Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(istio_requests_total{destination_service_name=~\"$service\", destination_service_namespace=~\"$namespace\"}[$__rate_interval])) by (source_workload, response_code)", "legendFormat": "{{ source_workload }} ({{ response_code }})", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Incoming Request Duration (p50, p95, p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(istio_request_duration_milliseconds_bucket{destination_service_name=~\"$service\", destination_service_namespace=~\"$namespace\"}[$__rate_interval])) by (le)) / 1000", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(istio_request_duration_milliseconds_bucket{destination_service_name=~\"$service\", destination_service_namespace=~\"$namespace\"}[$__rate_interval])) by (le)) / 1000", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(istio_request_duration_milliseconds_bucket{destination_service_name=~\"$service\", destination_service_namespace=~\"$namespace\"}[$__rate_interval])) by (le)) / 1000", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "Bps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "TCP Bytes Sent/Received",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(istio_tcp_sent_bytes_total{destination_service_name=~\"$service\", destination_service_namespace=~\"$namespace\"}[$__rate_interval]))", "legendFormat": "Sent", "refId": "A" },
        { "expr": "sum(rate(istio_tcp_received_bytes_total{destination_service_name=~\"$service\", destination_service_namespace=~\"$namespace\"}[$__rate_interval]))", "legendFormat": "Received", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["istio", "services"],
  "templating": {
    "list": [
      { "name": "datasource", "query": "prometheus", "type": "datasource" },
      { "name": "namespace", "query": "label_values(istio_requests_total, destination_service_namespace)", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "type": "query", "refresh": 2 },
      { "name": "service", "query": "label_values(istio_requests_total{destination_service_namespace=~\"$namespace\"}, destination_service_name)", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "type": "query", "refresh": 2 }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Istio Service Detail",
  "uid": "istio-service-detail"
}
