{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Request Rate by Ingress",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(nginx_ingress_controller_requests[$__rate_interval])) by (ingress, namespace)",
          "legendFormat": "{{ namespace }}/{{ ingress }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(nginx_ingress_controller_requests{status=~\"[45].*\"}[$__rate_interval])) by (ingress, status)",
          "legendFormat": "{{ ingress }} - {{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Request Latency (p95)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(nginx_ingress_controller_request_duration_seconds_bucket[$__rate_interval])) by (le, ingress))",
          "legendFormat": "p95 {{ ingress }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "Bps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "Network I/O",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(nginx_ingress_controller_response_size_sum[$__rate_interval])) by (ingress)",
          "legendFormat": "Response {{ ingress }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(nginx_ingress_controller_request_size_sum[$__rate_interval])) by (ingress)",
          "legendFormat": "Request {{ ingress }}",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ingress-nginx"],
  "templating": {
    "list": [
      { "name": "datasource", "query": "prometheus", "type": "datasource" }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "NGINX Ingress Controller",
  "uid": "nginx-ingress-overview"
