{
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Request Rate by Service",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(activator_request_count[$__rate_interval])) by (namespace_name, configuration_name)", "legendFormat": "{{ namespace_name }}/{{ configuration_name }}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Request Latency (p95)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(activator_request_latencies_bucket[$__rate_interval])) by (le, configuration_name))", "legendFormat": "p95 {{ configuration_name }}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Active Pod Count (Autoscaler)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(autoscaler_actual_pods) by (namespace_name, configuration_name)", "legendFormat": "{{ namespace_name }}/{{ configuration_name }}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "Desired vs Actual Pods",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(autoscaler_desired_pods) by (configuration_name)", "legendFormat": "desired {{ configuration_name }}", "refId": "A" },
        { "expr": "sum(autoscaler_actual_pods) by (configuration_name)", "legendFormat": "actual {{ configuration_name }}", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["knative"],
  "templating": {
    "list": [
      { "name": "datasource", "query": "prometheus", "type": "datasource" }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Knative Serving",
  "uid": "knative-serving"
}
